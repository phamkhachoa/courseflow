SERVER_PORT=8080
RECOMMENDATION_ML_DB_URL=jdbc:postgresql://localhost:5432/cf_recommendation_ml
RECOMMENDATION_ML_DB_USERNAME=courseflow
RECOMMENDATION_ML_DB_PASSWORD=courseflow
COURSEFLOW_INTERNAL_JWT_ALGORITHM=HS256
COURSEFLOW_INTERNAL_JWT_SECRET=courseflow-local-internal-jwt-secret-change-me-32
COURSEFLOW_INTERNAL_JWT_ISSUER=courseflow-token-converter
COURSEFLOW_INTERNAL_JWT_AUDIENCE=courseflow-services
COURSEFLOW_INTERNAL_JWT_MAX_TTL_SECONDS=900
COURSEFLOW_INTERNAL_JWT_CLOCK_SKEW_SECONDS=30
COURSEFLOW_INTERNAL_JWT_VERIFICATION_MODE=local
COURSEFLOW_INTERNAL_JWT_JWKS_URI=
COURSEFLOW_INTERNAL_JWT_JWKS_CACHE_TTL_SECONDS=300
COURSEFLOW_INTERNAL_JWT_JWKS_TIMEOUT_SECONDS=5
RECOMMENDATION_ML_DEFAULT_MAX_RELATED_PER_COURSE=24
RECOMMENDATION_ML_MAX_RELATED_PER_COURSE=100
RECOMMENDATION_ML_DEFAULT_MIN_SUPPORT=1
RECOMMENDATION_ML_MAX_TRAINING_EVENTS=250000
RECOMMENDATION_ML_EXPECTED_MIGRATION_REVISION=007_model_activation_governance
RECOMMENDATION_ML_TRAINING_JOB_LEASE_SECONDS=1800
RECOMMENDATION_ML_TRAINING_JOB_MAX_ATTEMPTS=3
RECOMMENDATION_ML_TRAINING_JOB_REQUEUE_DELAY_SECONDS=60
RECOMMENDATION_ML_TRAINING_PAYLOAD_RETENTION_DAYS=30
RECOMMENDATION_ML_PAYLOAD_SCRUB_INTERVAL_SECONDS=86400
RECOMMENDATION_ML_ACTIVE_MODEL_STALE_AFTER_SECONDS=604800
RECOMMENDATION_ML_REQUIRE_ACTIVE_MODEL_READY=false
RECOMMENDATION_ML_AUTO_ACTIVATE_TRAINED_MODELS=true
RECOMMENDATION_ML_SYNC_TRAINING_ENABLED=true
RECOMMENDATION_ML_MIN_ACTIVATION_EVENT_COUNT=10
RECOMMENDATION_ML_MIN_ACTIVATION_PRINCIPAL_COUNT=3
RECOMMENDATION_ML_MIN_ACTIVATION_COURSE_COUNT=2
RECOMMENDATION_ML_MIN_ACTIVATION_PAIR_COUNT=1
RECOMMENDATION_ML_MIN_ACTIVATION_QUALITY_SCORE=0.01
RECOMMENDATION_ML_DOCS_ENABLED=false
RECOMMENDATION_ML_RUN_MIGRATIONS=false

# Ops smoke / staging signoff
RECOMMENDATION_ML_SMOKE_URL=http://localhost:8080
RECOMMENDATION_ML_SMOKE_ENVIRONMENT=local
RECOMMENDATION_ML_SMOKE_REQUIRE_HTTPS_URLS=false
RECOMMENDATION_ML_SMOKE_REJECT_LOCAL_URLS=false
RECOMMENDATION_ML_SMOKE_ANALYTICS_URL=http://analytics-service:8080
RECOMMENDATION_ML_SMOKE_PROMETHEUS_URL=http://prometheus:9090
RECOMMENDATION_ML_SMOKE_REQUIRED_TARGETS=recommendation-ml|courseflow-services|recommendation-ml-service:8080,analytics|courseflow-services|analytics-service:8080
RECOMMENDATION_ML_SMOKE_REQUIRE_ACTIVE_MODEL=true
RECOMMENDATION_ML_SMOKE_MUTATION_FLOW_ENABLED=true
RECOMMENDATION_ML_SMOKE_EXPECT_SYNC_TRAIN_DISABLED=true
RECOMMENDATION_ML_SMOKE_REQUIRE_PREMINTED_TOKENS=true
RECOMMENDATION_ML_SMOKE_ANALYTICS_CLIENT_METRIC_REQUIRED=true
RECOMMENDATION_ML_SMOKE_ANALYTICS_CLIENT_METRIC_WINDOW=30m
RECOMMENDATION_ML_SMOKE_MAX_QUEUED_AGE_SECONDS=900
RECOMMENDATION_ML_SMOKE_MAX_RUNNING_AGE_SECONDS=3600
RECOMMENDATION_ML_SMOKE_MAX_PENDING_ACTIVATION_APPROVAL_AGE_SECONDS=86400
RECOMMENDATION_ML_SMOKE_MAX_TOKEN_TTL_SECONDS=900
RECOMMENDATION_ML_SMOKE_MAX_EVIDENCE_AGE_HOURS=24
RECOMMENDATION_ML_SMOKE_MAX_EVIDENCE_FUTURE_SKEW_MINUTES=10
RECOMMENDATION_ML_SMOKE_REQUIRED_ALERTS=RecommendationMlNoActiveModel,RecommendationMlTrainingJobsStuck,RecommendationMlMigrationNotReady,RecommendationMlMetricsRefreshFailing,RecommendationMlConsumerFallbackElevated
RECOMMENDATION_ML_SMOKE_CRITICAL_ALERTS=RecommendationMlNoActiveModel|RecommendationMlTrainingJobsStuck|RecommendationMlMigrationNotReady|RecommendationMlMetricsRefreshFailing|RecommendationMlConsumerFallbackElevated
RECOMMENDATION_ML_SMOKE_CI_PROVIDER=github_actions
