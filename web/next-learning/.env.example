# Public API gateway base. Used by Server Components and the browser.
COURSEFLOW_API_URL=http://localhost:28080/api
NEXT_PUBLIC_API_URL=http://localhost:28080/api

# keycloak enables Authorization Code + PKCE against the CourseFlow realm.
# Use legacy only for explicit local compatibility testing of the retired identity-service flow.
NEXT_PUBLIC_AUTH_MODE=keycloak
NEXT_PUBLIC_KEYCLOAK_ISSUER_URI=http://localhost:18080/realms/courseflow
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=courseflow-learner-web
