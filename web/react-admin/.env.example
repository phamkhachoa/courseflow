VITE_API_GATEWAY_URL=http://localhost:28080/api

# keycloak enables Authorization Code + PKCE against the CourseFlow realm.
# Use legacy only for explicit local compatibility testing of the retired identity-service flow.
VITE_AUTH_MODE=keycloak
VITE_KEYCLOAK_ISSUER_URI=http://localhost:18080/realms/courseflow
VITE_KEYCLOAK_CLIENT_ID=courseflow-admin-web
