# ===========================================================================
# CourseFlow — root .gitignore (Flutter app + Java/Maven backend + Web)
# ===========================================================================

# ----- OS / System ---------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----- Editors / IDE --------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.swp
*.swo
*~

# ----- Env / Secrets --------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets.*

# ===========================================================================
# Flutter / Dart  (app/)
# ===========================================================================
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
.fvm/
**/doc/api/
*.lock.bak

# Generated code (uncomment if you commit them, by default ignored)
*.g.dart
*.freezed.dart
*.config.dart
*.mocks.dart

# Platform build artifacts
**/android/.gradle/
**/android/captures/
**/android/local.properties
**/android/key.properties
**/android/app/release/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Pods/
**/ios/.symlinks/
**/ios/Runner.xcworkspace/xcuserdata/
**/macos/Pods/
**/windows/flutter/ephemeral/
**/linux/flutter/ephemeral/
**/web/build/

# ===========================================================================
# Java / Maven  (backend/)
# ===========================================================================
target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar
dependency-reduced-pom.xml
.flattened-pom.xml

# Gradle (if any module uses it)
.gradle/
gradle-app.setting

# Spring Boot
*.log
logs/
backend/backups/

# ===========================================================================
# Python / ML services
# ===========================================================================
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# ===========================================================================
# Node / Next.js / React / Vite  (web/)
# ===========================================================================
node_modules/
.pnp
.pnp.js
.yarn/

# Build outputs
.next/
out/
dist/
build/
.turbo/
.vercel/

# Testing / coverage
coverage/
.nyc_output/

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# Vite
*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===========================================================================
# Misc
# ===========================================================================
tmp/
temp/
*.tmp
*.bak
