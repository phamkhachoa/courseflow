{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise.local/dp/contracts/events/customer.support_case.changed.v1.schema.json",
  "title": "Customer Support Case Changed Event Payload v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventType",
    "orgId",
    "caseId",
    "accountId",
    "customerIdHash",
    "channel",
    "priority",
    "caseType",
    "caseStatus",
    "createdAt",
    "firstResponseSlaTargetMinutes",
    "resolutionSlaTargetMinutes",
    "firstResponseMinutes",
    "resolutionMinutes",
    "reopenedCount",
    "escalationCount",
    "sourceSystemRecordIdHash",
    "changedAt"
  ],
  "properties": {
    "eventType": {
      "type": "string",
      "enum": ["SUPPORT_CASE_CHANGED"]
    },
    "orgId": {
      "type": "string",
      "format": "uuid"
    },
    "caseId": {
      "type": "string",
      "minLength": 6,
      "maxLength": 120
    },
    "accountId": {
      "type": "string",
      "minLength": 6,
      "maxLength": 120
    },
    "customerIdHash": {
      "type": "string",
      "minLength": 32,
      "maxLength": 128
    },
    "channel": {
      "type": "string",
      "enum": ["WEB", "EMAIL", "CHAT", "PHONE", "API", "SOCIAL", "INTERNAL"]
    },
    "priority": {
      "type": "string",
      "enum": ["LOW", "NORMAL", "HIGH", "URGENT", "CRITICAL"]
    },
    "caseType": {
      "type": "string",
      "enum": ["INCIDENT", "QUESTION", "BILLING", "TECHNICAL", "ACCOUNT", "FEATURE_REQUEST", "OTHER"]
    },
    "caseStatus": {
      "type": "string",
      "enum": ["OPEN", "PENDING", "RESOLVED", "CLOSED", "ESCALATED"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "firstResponseAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "resolvedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "firstResponseSlaTargetMinutes": {
      "type": "integer",
      "minimum": 1
    },
    "resolutionSlaTargetMinutes": {
      "type": "integer",
      "minimum": 1
    },
    "firstResponseMinutes": {
      "type": "integer",
      "minimum": 0
    },
    "resolutionMinutes": {
      "type": "integer",
      "minimum": 0
    },
    "reopenedCount": {
      "type": "integer",
      "minimum": 0
    },
    "escalationCount": {
      "type": "integer",
      "minimum": 0
    },
    "satisfactionScore": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 5
    },
    "sourceSystemRecordIdHash": {
      "type": "string",
      "minLength": 32,
      "maxLength": 128
    },
    "changedAt": {
      "type": "string",
      "format": "date-time"
    },
    "correlationTags": {
      "type": ["object", "null"],
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      },
      "maxProperties": 30
    }
  }
}
