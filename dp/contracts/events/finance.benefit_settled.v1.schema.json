{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise.local/dp/contracts/events/finance.benefit_settled.v1.schema.json",
  "title": "Finance Benefit Settled Event Payload v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventType",
    "orgId",
    "sourceProductId",
    "benefitTransactionId",
    "reconciliationKey",
    "benefitType",
    "orderId",
    "paymentId",
    "currency",
    "expectedAmountCents",
    "actualAmountCents",
    "expectedPoints",
    "actualPoints",
    "listPriceCents",
    "finalAmountCents",
    "paidAmountCents",
    "committedDiscountCents",
    "loyaltyPointsEarned",
    "loyaltyPointsBurned",
    "rewardAmountCents",
    "refundAmountCents",
    "settlementStatus",
    "benefitStatus",
    "accountingDate",
    "settledAt"
  ],
  "properties": {
    "eventType": {
      "type": "string",
      "enum": ["BENEFIT_SETTLED"]
    },
    "orgId": {
      "type": "string",
      "format": "uuid"
    },
    "sourceProductId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "benefitTransactionId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 120
    },
    "reconciliationKey": {
      "type": "string",
      "minLength": 8,
      "maxLength": 160
    },
    "benefitType": {
      "type": "string",
      "enum": ["DISCOUNT", "LOYALTY_EARN", "LOYALTY_BURN", "REWARD", "REFUND", "MIXED"]
    },
    "orderId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 120
    },
    "paymentId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 120
    },
    "entitlementId": {
      "type": ["string", "null"],
      "minLength": 3,
      "maxLength": 120
    },
    "beneficiaryIdHash": {
      "type": ["string", "null"],
      "minLength": 32,
      "maxLength": 128
    },
    "itemId": {
      "type": ["string", "null"],
      "minLength": 3,
      "maxLength": 120
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "expectedAmountCents": {
      "type": "integer"
    },
    "actualAmountCents": {
      "type": "integer"
    },
    "expectedPoints": {
      "type": "integer"
    },
    "actualPoints": {
      "type": "integer"
    },
    "listPriceCents": {
      "type": "integer",
      "minimum": 0
    },
    "finalAmountCents": {
      "type": "integer",
      "minimum": 0
    },
    "paidAmountCents": {
      "type": "integer",
      "minimum": 0
    },
    "committedDiscountCents": {
      "type": "integer",
      "minimum": 0
    },
    "loyaltyPointsEarned": {
      "type": "integer",
      "minimum": 0
    },
    "loyaltyPointsBurned": {
      "type": "integer",
      "minimum": 0
    },
    "rewardAmountCents": {
      "type": "integer",
      "minimum": 0
    },
    "refundAmountCents": {
      "type": "integer",
      "minimum": 0
    },
    "settlementStatus": {
      "type": "string",
      "enum": ["SETTLED", "PENDING", "FAILED", "REVERSED"]
    },
    "benefitStatus": {
      "type": "string",
      "enum": ["COMMITTED", "PENDING", "REVERSED", "MISSING"]
    },
    "accountingDate": {
      "type": "string",
      "format": "date"
    },
    "settledAt": {
      "type": "string",
      "format": "date-time"
    },
    "reasonCode": {
      "type": ["string", "null"],
      "maxLength": 120
    },
    "correlationTags": {
      "type": ["object", "null"],
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      },
      "maxProperties": 30
    }
  }
}
