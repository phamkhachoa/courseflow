{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise.local/df/contracts/events/gradebook.final_grade.updated.v1.schema.json",
  "title": "Gradebook Final Grade Updated Event Payload v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "orgId",
    "courseId",
    "gradebookId",
    "learnerIdHash",
    "finalGradeValue",
    "finalGradeScale",
    "gradeUpdatedAt"
  ],
  "properties": {
    "orgId": {
      "type": "string",
      "format": "uuid"
    },
    "courseId": {
      "type": "string",
      "format": "uuid"
    },
    "gradebookId": {
      "type": "string",
      "format": "uuid"
    },
    "learnerIdHash": {
      "type": "string",
      "minLength": 32,
      "maxLength": 128
    },
    "gradingPeriodId": {
      "type": ["string", "null"],
      "maxLength": 80
    },
    "finalGradeValue": {
      "type": "number"
    },
    "finalGradeScale": {
      "type": "string",
      "enum": ["PERCENT", "POINTS", "LETTER", "PASS_FAIL"]
    },
    "finalGradeLetter": {
      "type": ["string", "null"],
      "maxLength": 8
    },
    "gradeUpdatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "changeReason": {
      "type": ["string", "null"],
      "enum": ["CALCULATION", "MANUAL_OVERRIDE", "IMPORT", "CORRECTION", null]
    },
    "metadata": {
      "type": ["object", "null"],
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      },
      "maxProperties": 30
    }
  }
}
