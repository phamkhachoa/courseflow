{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise.local/df/contracts/events/compliance.identity_subject.changed.v1.schema.json",
  "title": "Compliance Identity Subject Changed Event Payload v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventType",
    "orgId",
    "subjectIdHash",
    "subjectType",
    "lifecycleStatus",
    "riskLevel",
    "entitlementCount",
    "privilegedEntitlementCount",
    "mfaEnabled",
    "changedAt"
  ],
  "properties": {
    "eventType": {
      "type": "string",
      "enum": ["IDENTITY_SUBJECT_CHANGED"]
    },
    "orgId": {
      "type": "string",
      "format": "uuid"
    },
    "subjectIdHash": {
      "type": "string",
      "minLength": 32,
      "maxLength": 128
    },
    "subjectType": {
      "type": "string",
      "enum": ["USER", "SERVICE_ACCOUNT", "ADMIN", "WORKFORCE_USER", "EMPLOYEE", "CUSTOMER_USER"]
    },
    "lifecycleStatus": {
      "type": "string",
      "enum": ["PENDING", "ACTIVE", "SUSPENDED", "DEPROVISIONED"]
    },
    "riskLevel": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
    },
    "entitlementCount": {
      "type": "integer",
      "minimum": 0
    },
    "privilegedEntitlementCount": {
      "type": "integer",
      "minimum": 0
    },
    "mfaEnabled": {
      "type": "boolean"
    },
    "lastAccessAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "changedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceProductId": {
      "type": ["string", "null"],
      "minLength": 3,
      "maxLength": 80,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "correlationTags": {
      "type": ["object", "null"],
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      },
      "maxProperties": 30
    }
  }
}
